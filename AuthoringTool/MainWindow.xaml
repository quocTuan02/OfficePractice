<Window x:Class="AuthoringTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AuthoringTool.ViewModels"
        Title="Authoring Tool – OfficePractice"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <!-- Resources MUST come before content that uses them -->
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#313244"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#11111B">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App Title -->
            <Border Grid.Row="0" Padding="20,20,20,16">
                <StackPanel>
                    <TextBlock Text="Authoring Tool" FontSize="15" FontWeight="Bold"
                               Foreground="#CDD6F4"/>
                    <TextBlock Text="OfficePractice" FontSize="11" Foreground="#45475A"/>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Grid.Row="1" Height="1" Fill="#313244" Margin="16,0"/>

            <!-- Navigation Items -->
            <StackPanel Grid.Row="2" Margin="0,12,0,0">

                <Button Command="{Binding NavigateTemplatesCommand}"
                        Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Template Manager" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#CDD6F4"/>
                            <TextBlock Text="Quản lý file mẫu" FontSize="11" Foreground="#585B70"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateTasksCommand}"
                        Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Task Editor" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#CDD6F4"/>
                            <TextBlock Text="Tạo và sắp xếp task" FontSize="11" Foreground="#585B70"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateScoringCommand}"
                        Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚖" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Scoring Designer" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#CDD6F4"/>
                            <TextBlock Text="Thiết kế quy tắc chấm" FontSize="11" Foreground="#585B70"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigatePackagerCommand}"
                        Style="{StaticResource NavButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Test Packager" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#CDD6F4"/>
                            <TextBlock Text="Đóng gói bài thi" FontSize="11" Foreground="#585B70"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Bottom Info -->
            <Border Grid.Row="3" Padding="20,12" BorderBrush="#313244" BorderThickness="0,1,0,0">
                <TextBlock Text="v1.0 – Prototype" FontSize="10" Foreground="#45475A"/>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <ContentControl Content="{Binding CurrentModule}"/>
        </Grid>
    </Grid>
</Window>
