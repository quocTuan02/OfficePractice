<UserControl x:Class="AuthoringTool.Views.TaskEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#181825" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Task Editor" FontSize="16" FontWeight="SemiBold"
                           Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <Button Content="+ Bài Thi Mới" Command="{Binding NewTestCommand}"
                        Background="#A6E3A1" Foreground="#1E1E2E"
                        BorderThickness="0" Padding="12,7" Cursor="Hand" FontWeight="SemiBold"/>
                <Button Content="Xóa Bài Thi" Command="{Binding DeleteTestCommand}" Margin="8,0,0,0"
                        Background="#F38BA8" Foreground="#1E1E2E"
                        BorderThickness="0" Padding="12,7" Cursor="Hand" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Main content: 3 columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Test List -->
            <Grid Grid.Column="0" Background="#181825">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DANH SÁCH BÀI THI" FontSize="11"
                           Foreground="#585B70" FontWeight="SemiBold" Margin="16,12,16,8"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Tests}"
                         SelectedItem="{Binding SelectedTest}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="#CDD6F4" FontSize="13"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} tasks}"
                                               FontSize="11" Foreground="#585B70"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="#45475A"/>
                                    <TextBlock Text="{Binding TotalTimeMinutes, StringFormat={}{0} phút}"
                                               FontSize="11" Foreground="#585B70"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#313244"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#45475A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <Rectangle Grid.Column="1" Fill="#313244"/>

            <!-- Task Detail Area -->
            <Grid Grid.Column="2" Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Test Info Summary -->
                <Border Grid.Row="0" Background="#181825" Padding="16,10"
                        Visibility="{Binding HasTestSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#A6ADC8" FontSize="12" VerticalAlignment="Center">
                            <Run Text="Bài thi: "/>
                            <Run Text="{Binding SelectedTest.Name, Mode=OneWay}" Foreground="#CDD6F4" FontWeight="SemiBold"/>
                            <Run Text="    Tổng điểm: "/>
                            <Run Text="{Binding SelectedTest.TotalPoints, Mode=OneWay}" Foreground="#A6E3A1" FontWeight="SemiBold"/>
                            <Run Text=" điểm    Thời gian: "/>
                            <Run Text="{Binding SelectedTest.TotalTimeMinutes, Mode=OneWay}" Foreground="#F9E2AF" FontWeight="SemiBold"/>
                            <Run Text=" phút"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Task Toolbar -->
                <Border Grid.Row="1" Background="#313244" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TASKS" FontSize="11" Foreground="#585B70"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="+ Thêm Task" Command="{Binding AddTaskCommand}"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="10,6" Cursor="Hand" FontWeight="SemiBold"/>
                        <Button Content="Sửa" Command="{Binding EditTaskCommand}" Margin="6,0,0,0"
                                Background="#45475A" Foreground="#CDD6F4"
                                BorderThickness="0" Padding="10,6" Cursor="Hand"/>
                        <Button Content="Xóa" Command="{Binding DeleteTaskCommand}" Margin="6,0,0,0"
                                Background="#F38BA8" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="10,6" Cursor="Hand"/>
                        <Button Content="↑" Command="{Binding MoveUpCommand}" Margin="10,0,0,0"
                                Background="#45475A" Foreground="#CDD6F4"
                                BorderThickness="0" Padding="10,6" Cursor="Hand"
                                ToolTip="Di chuyển lên"/>
                        <Button Content="↓" Command="{Binding MoveDownCommand}" Margin="4,0,0,0"
                                Background="#45475A" Foreground="#CDD6F4"
                                BorderThickness="0" Padding="10,6" Cursor="Hand"
                                ToolTip="Di chuyển xuống"/>
                    </StackPanel>
                </Border>

                <!-- Task List as DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="#1E1E2E"
                          RowBackground="#1E1E2E"
                          AlternatingRowBackground="#181825"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#313244"
                          BorderThickness="0"
                          HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#313244"/>
                            <Setter Property="Foreground" Value="#A6ADC8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderBrush" Value="#45475A"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#45475A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="#CDD6F4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="50" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Mục Tiêu" Binding="{Binding Objective}" Width="200" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Hướng Dẫn" Binding="{Binding Instruction}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="Foreground" Value="#A6ADC8"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="File Template" Binding="{Binding TemplateFile}" Width="160" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Điểm" Binding="{Binding Points}" Width="70" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Rules" Binding="{Binding ScoringRules.Count, Mode=OneWay}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#F9E2AF"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#11111B" Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#585B70" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
