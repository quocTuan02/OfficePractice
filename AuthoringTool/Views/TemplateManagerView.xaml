<UserControl x:Class="AuthoringTool.Views.TemplateManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#181825" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Template Manager" FontSize="16" FontWeight="SemiBold"
                           Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <Button Content="+ New Template" Command="{Binding NewCommand}"
                        Background="#89B4FA" Foreground="#1E1E2E"
                        BorderThickness="0" Padding="12,7" Cursor="Hand" FontWeight="SemiBold"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"
                        Background="#45475A" Foreground="#CDD6F4"
                        BorderThickness="0" Padding="12,7" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Content: List + Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Template List -->
            <Grid Grid.Column="0" Background="#181825">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DANH SÁCH TEMPLATE" FontSize="11"
                           Foreground="#585B70" FontWeight="SemiBold"
                           Margin="16,12,16,8"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="#CDD6F4" FontSize="13"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Border Background="#313244" CornerRadius="3" Padding="5,1">
                                        <TextBlock Text="{Binding OfficeType}" FontSize="10"
                                                   Foreground="#89B4FA"/>
                                    </Border>
                                    <TextBlock Text="{Binding CreatedDate, StringFormat=dd/MM/yyyy}"
                                               FontSize="10" Foreground="#585B70" Margin="6,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#313244"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#45475A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="1" Background="#313244" ResizeBehavior="PreviousAndNext"/>

            <!-- Detail Panel -->
            <ScrollViewer Grid.Column="2" Background="#1E1E2E" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24" IsEnabled="{Binding HasSelection}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="THÔNG TIN TEMPLATE" FontSize="11" Foreground="#585B70"
                               FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Tên" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Mô tả" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SelectedTemplate.Description, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Loại Office" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="#313244" CornerRadius="4" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,14">
                        <TextBlock Text="{Binding SelectedTemplate.OfficeType}"
                                   Foreground="#89B4FA" FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Text="File Template" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SelectedTemplate.FilePath}" IsReadOnly="True"
                                 Background="#181825" Foreground="#585B70"/>
                        <Button Grid.Column="2" Content="Chọn File" Command="{Binding BrowseFileCommand}"
                                Background="#45475A" Foreground="#CDD6F4"
                                BorderThickness="0" Padding="10,7" Cursor="Hand"/>
                    </Grid>

                    <Separator Background="#313244" Margin="0,8,0,16"/>

                    <WrapPanel>
                        <Button Content="Mở trong Office" Command="{Binding OpenInOfficeCommand}"
                                Background="#A6E3A1" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="12,8" Cursor="Hand" FontWeight="SemiBold"
                                Margin="0,0,8,8"/>
                        <Button Content="Lưu Thông Tin" Command="{Binding SaveMetaCommand}"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="12,8" Cursor="Hand" FontWeight="SemiBold"
                                Margin="0,0,8,8"/>
                        <Button Content="Xóa Template" Command="{Binding DeleteCommand}"
                                Background="#F38BA8" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="12,8" Cursor="Hand" FontWeight="SemiBold"
                                Margin="0,0,8,8"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#11111B" Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#585B70" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
