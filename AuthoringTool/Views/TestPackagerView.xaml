<UserControl x:Class="AuthoringTool.Views.TestPackagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#181825" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Test Packager" FontSize="16" FontWeight="SemiBold"
                           Foreground="#CDD6F4" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <Button Content="Import Package" Command="{Binding ImportCommand}"
                        Background="#45475A" Foreground="#CDD6F4"
                        BorderThickness="0" Padding="12,7" Cursor="Hand"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"
                        Background="#45475A" Foreground="#CDD6F4"
                        BorderThickness="0" Padding="12,7" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Test List -->
            <Grid Grid.Column="0" Background="#181825">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CHỌN BÀI THI" FontSize="11" Foreground="#585B70"
                           FontWeight="SemiBold" Margin="16,12,16,8"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Tests}"
                         SelectedItem="{Binding SelectedTest}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="#CDD6F4" FontSize="13"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Tasks.Count, StringFormat={}{0} tasks}"
                                               FontSize="11" Foreground="#585B70"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="#45475A"/>
                                    <TextBlock Text="{Binding TotalPoints, StringFormat={}{0} đ}"
                                               FontSize="11" Foreground="#A6E3A1"/>
                                    <TextBlock Text=" · v" FontSize="11" Foreground="#45475A"/>
                                    <TextBlock Text="{Binding Version}" FontSize="11" Foreground="#585B70"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#313244"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#45475A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <Rectangle Grid.Column="1" Fill="#313244"/>

            <!-- Package Actions -->
            <ScrollViewer Grid.Column="2" Background="#1E1E2E" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <!-- Actions section -->
                    <TextBlock Text="ĐÓNG GÓI BÀI THI" FontSize="11" Foreground="#585B70"
                               FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <WrapPanel Margin="0,0,0,24">
                        <Button Content="Validate" Command="{Binding ValidateCommand}"
                                Background="#F9E2AF" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="14,10" Cursor="Hand"
                                FontWeight="SemiBold" Margin="0,0,10,10"/>
                        <Button Content="Export .ZIP" Command="{Binding ExportZipCommand}"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="14,10" Cursor="Hand"
                                FontWeight="SemiBold" Margin="0,0,10,10"/>
                        <Button Content="Export Folder" Command="{Binding ExportFolderCommand}"
                                Background="#A6E3A1" Foreground="#1E1E2E"
                                BorderThickness="0" Padding="14,10" Cursor="Hand"
                                FontWeight="SemiBold" Margin="0,0,10,10"/>
                    </WrapPanel>

                    <!-- Package Structure Preview -->
                    <TextBlock Text="CẤU TRÚC PACKAGE" FontSize="11" Foreground="#585B70"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Border Background="#181825" CornerRadius="6" Padding="16" Margin="0,0,0,24">
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#A6ADC8">
                            <Run Text="{Binding SelectedTest.Name, StringFormat={}{0}_v}" Foreground="#CDD6F4" FontWeight="SemiBold"/>
                            <Run Text="{Binding SelectedTest.Version}" Foreground="#CDD6F4" FontWeight="SemiBold"/>
                            <Run Text="/"/>
                            <LineBreak/>
                            <Run Text="  ├─ test.json" Foreground="#89B4FA"/>
                            <LineBreak/>
                            <Run Text="  ├─ Templates/"/>
                            <LineBreak/>
                            <Run Text="  └─ ScoringRules/"/>
                        </TextBlock>
                    </Border>

                    <!-- Validation Results -->
                    <TextBlock Text="KẾT QUẢ VALIDATION" FontSize="11" Foreground="#585B70"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding ValidationResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="12,8" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1E3A1E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                    <Setter Property="Background" Value="#3A1E1E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                    <Setter Property="Background" Value="#3A321E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,8,0"
                                                   FontSize="14" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                            <Setter Property="Foreground" Value="#F38BA8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Foreground" Value="#F9E2AF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Message}" Foreground="#CDD6F4"
                                                   FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#11111B" Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#585B70" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
