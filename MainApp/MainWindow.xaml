<Window x:Class="MainApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OfficePractice" Height="700" Width="1200"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen"
        LocationChanged="OnWindowMoved" SizeChanged="OnWindowResized"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Grid Grid.Row="0" Background="#181825">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="OfficePractice" Foreground="#CDD6F4"
                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="16,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Margin="8,0">
                <Button Content="Excel" x:Name="BtnExcel" Click="OpenExcel_Click"
                        Background="#217346" Foreground="White" BorderBrush="Transparent"
                        Padding="16,6" Margin="4,0" FontSize="13" Cursor="Hand"/>
                <Button Content="Word" x:Name="BtnWord" Click="OpenWord_Click"
                        Background="#2B5FD9" Foreground="White" BorderBrush="Transparent"
                        Padding="16,6" Margin="4,0" FontSize="13" Cursor="Hand"/>
                <Button Content="Đóng Office" x:Name="BtnClose" Click="CloseOffice_Click"
                        Background="#45475A" Foreground="White" BorderBrush="Transparent"
                        Padding="16,6" Margin="4,0" FontSize="13" Cursor="Hand"
                        IsEnabled="False"/>
                <Button Content="📦 Load Package" x:Name="BtnLoadPackage" Click="LoadPackage_Click"
                        Background="#CBA6F7" Foreground="#1E1E2E" BorderBrush="Transparent"
                        Padding="16,6" Margin="12,0,4,0" FontSize="13" Cursor="Hand"
                        FontWeight="SemiBold"/>
                <Button x:Name="BtnSubmitToolbar" Content="✓ Nộp bài"
                        Click="SubmitAndScore_Click"
                        Background="#A6E3A1" Foreground="#1E1E2E" BorderBrush="Transparent"
                        Padding="16,6" Margin="8,0,4,0" FontSize="13" Cursor="Hand"
                        FontWeight="SemiBold" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Ellipse x:Name="PipeStatusDot" Width="8" Height="8" Fill="#A6E3A1" Margin="0,0,6,0"/>
                <TextBlock x:Name="PipeStatusText" Text="Pipe: Active" Foreground="#6C7086"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </StackPanel>
        </Grid>

        <!-- Main split area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="400" x:Name="OfficeColumn"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="360" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Office placeholder -->
            <Border Grid.Column="0" x:Name="OfficePanelBorder" Background="#11111B"
                    BorderBrush="#313244" BorderThickness="0,0,0,0">
                <StackPanel x:Name="OfficePlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Chọn ứng dụng Office ở trên" Foreground="#45475A"
                               FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Excel hoặc Word sẽ hiện ở đây" Foreground="#313244"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#313244" Cursor="SizeWE"/>

            <!-- Right: Task panel -->
            <Grid Grid.Column="2" Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Exercise header -->
                <Border Grid.Row="0" Background="#181825" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="BÀI TẬP THỰC HÀNH" Foreground="#6C7086"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ExerciseTitle" Text="Excel — Nhập liệu cơ bản"
                                   Foreground="#CDD6F4" FontSize="15" FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Row 1: Task selector (visible when package loaded) -->
                <Border Grid.Row="1" x:Name="TaskSelectorBorder" Background="#313244"
                        Margin="0,1,0,0" Padding="12,8" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Task:" Foreground="#A6ADC8" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="TaskComboBox" MinWidth="180"
                                  Background="#45475A" Foreground="#CDD6F4" BorderBrush="#585B70"
                                  SelectionChanged="TaskComboBox_SelectionChanged"/>
                        <TextBlock x:Name="TaskPointsLabel" Foreground="#A6E3A1"
                                   FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Row 2: Instructions -->
                <Border Grid.Row="2" Background="#181825" Margin="0,1,0,0" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="HƯỚNG DẪN" Foreground="#6C7086"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel x:Name="StepsPanel">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="20" Height="20" CornerRadius="10"
                                        Background="#313244" Margin="0,0,8,0">
                                    <TextBlock Text="1" Foreground="#CDD6F4" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Mở workbook mới trong Excel" Foreground="#BAC2DE"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="20" Height="20" CornerRadius="10"
                                        Background="#313244" Margin="0,0,8,0">
                                    <TextBlock Text="2" Foreground="#CDD6F4" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Nhập dữ liệu vào các cell A1:E5" Foreground="#BAC2DE"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="20" Height="20" CornerRadius="10"
                                        Background="#313244" Margin="0,0,8,0">
                                    <TextBlock Text="3" Foreground="#CDD6F4" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Lưu file với tên MOS_Test.xlsx" Foreground="#BAC2DE"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Row 3: Event log -->
                <Grid Grid.Row="3" Margin="0,1,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#181825" Padding="16,8">
                        <DockPanel>
                            <TextBlock Text="HOẠT ĐỘNG" Foreground="#6C7086"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="Xóa" DockPanel.Dock="Right" Click="ClearLog_Click"
                                    Background="Transparent" Foreground="#6C7086"
                                    BorderBrush="Transparent" FontSize="11" Cursor="Hand" Padding="8,2"/>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#11111B">
                        <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogText" Foreground="#BAC2DE" Padding="12"
                                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Row 4: Submit button -->
                <Border Grid.Row="4" Background="#181825" Padding="16,12">
                    <Button x:Name="BtnSubmit" Content="Nộp bài"
                            Click="SubmitAndScore_Click"
                            Background="#A6E3A1" Foreground="#1E1E2E"
                            BorderBrush="Transparent" FontSize="14" FontWeight="Bold"
                            Padding="0,10" Cursor="Hand" HorizontalAlignment="Stretch"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
