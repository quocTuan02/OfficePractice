<Window x:Class="MainApp.ScoringResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kết Quả Chấm Điểm"
        Width="540" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Score summary header -->
        <Border Grid.Row="0" Padding="24,20">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1A2E1A"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AllPassed}" Value="False">
                            <Setter Property="Background" Value="#2E1A1A"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock x:Name="TaskLabel" Text="Task 1" Foreground="#585B70"
                           FontSize="12" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ScoreText" FontSize="36" FontWeight="Bold" Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#A6E3A1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AllPassed}" Value="False">
                                        <Setter Property="Foreground" Value="#F38BA8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="SummaryText" Foreground="#CDD6F4"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubSummaryText" Foreground="#A6ADC8" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Column headers -->
        <Border Grid.Row="1" Background="#181825" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Rule" Foreground="#585B70"
                           FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="Thực tế" Foreground="#585B70"
                           FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="Điểm" Foreground="#585B70"
                           FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Rule results list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16,10" BorderThickness="0,0,0,1"
                                BorderBrush="#313244">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A2E1A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Passed}" Value="False">
                                            <Setter Property="Background" Value="#2E1A1A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                           FontSize="14" FontWeight="Bold" VerticalAlignment="Top"
                                           Margin="0,1,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Passed}" Value="False">
                                                    <Setter Property="Foreground" Value="#F38BA8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Margin="4,0,8,0">
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="#CDD6F4" FontSize="12"
                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Details}" Foreground="#A6ADC8"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding ActualValue}"
                                           Foreground="#585B70" FontSize="11"
                                           VerticalAlignment="Top" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="3" VerticalAlignment="Top"
                                           HorizontalAlignment="Right"
                                           FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Passed}" Value="False">
                                                    <Setter Property="Foreground" Value="#585B70"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding PointsEarned, Mode=OneWay}"/>
                                    <Run Text="/" Foreground="#45475A"/>
                                    <Run Text="{Binding PointsMax, Mode=OneWay}" Foreground="#45475A"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Close button -->
        <Border Grid.Row="3" Background="#181825" Padding="16,12">
            <Button Content="Đóng" Click="Close_Click"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderBrush="Transparent" FontSize="13"
                    Padding="24,8" Cursor="Hand" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
